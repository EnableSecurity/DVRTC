# Baresip configuration for call generation

# Module path for Debian
module_path		/usr/lib/baresip/modules

# Audio settings - play WAV files for realistic RTP bleed demo
audio_player		aufile,/dev/null
audio_source		aufile,/home/baresip/sounds/current.wav
audio_alert		aufile,/dev/null

# Disable video
video_source
video_display

# SIP settings - Use port 0 for random/ephemeral port to avoid conflicts when scaled
sip_listen		0.0.0.0:0

net_af			ipv4

# Call settings
call_local_timeout	60
# Keep one active call per helper. This avoids local overlap if a previous
# hangup has not completed yet.
call_max_calls		1

# ctrl_tcp for in-process dial / hangup control. Keeping a single baresip
# process alive avoids repeated process teardown/startup churn. The port is
# templated per service because the call generators share the host network.
ctrl_tcp_listen		127.0.0.1:__CTRL_TCP_PORT__

# Audio format - must match WAV files (8kHz mono)
audio_srate		8000
audio_channels		1

# Audio codec
audio_codecs		PCMU/8000/1,PCMA/8000/1

# Module loading
module			menu.so
module			account.so
module			g711.so
module			aufile.so
module			uuid.so
module			ctrl_tcp.so

# Auto answer off - we're making calls, not receiving
auto_answer		no

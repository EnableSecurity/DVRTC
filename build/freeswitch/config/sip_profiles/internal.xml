<profile name="internal">
  <gateways>
  </gateways>

  <aliases>
  </aliases>

  <domains>
    <domain name="default" parse="true"/>
  </domains>

  <settings>
    <param name="sip-ip" value="127.0.0.1"/>
    <param name="sip-port" value="5090"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>

    <!-- RTP port range -->
    <param name="rtp-start-port" value="10000"/>
    <param name="rtp-end-port" value="15000"/>

    <param name="context" value="default"/>
    <param name="codec-prefs" value="$${global_codec_prefs}"/>

    <!-- Allow all codecs -->
    <param name="inbound-codec-negotiation" value="generous"/>

    <!-- NAT settings - let OpenSIPS handle NAT via rtpproxy -->
    <param name="ext-rtp-ip" value="auto-nat"/>
    <param name="ext-sip-ip" value="auto-nat"/>

    <!-- Authentication -->
    <param name="challenge-realm" value="auto_from"/>
    <param name="accept-blind-reg" value="false"/>
    <param name="accept-blind-auth" value="false"/>
    <param name="force-register-domain" value="default"/>
    <param name="force-subscription-domain" value="default"/>

    <!-- Accept calls from localhost (OpenSIPS) -->
    <param name="apply-inbound-acl" value="allowall"/>

    <!-- Allow registrations -->
    <param name="disable-register" value="false"/>
  </settings>
</profile>
